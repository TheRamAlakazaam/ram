{
  "name": "ram-portfolio",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "npm@10.9.4",
  "description": "A personal portfolio and publishing site for photography, essays, dev logs, and notes.",
  "author": "R. Martinez",
  "license": "MIT",
  "keywords": [
    "astro",
    "portfolio",
    "photography",
    "blog",
    "seo",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "yaml": "^2.8.3"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "clean": "rimraf dist .astro",
    "cf:deploy": "npm run build && wrangler pages deploy dist",
    "cf:dev": "npm run build && wrangler pages dev dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.ts,.astro --fix",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "images:prep": "node scripts/prepare-images.mjs",
    "postinstall": "node scripts/patch-astro-font-runtime-export.mjs",
    "type-check": "astro check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "astro": "^5.14.1",
    "astro-robots-txt": "^1.0.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^9.35.0",
    "eslint": "^9.35.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "wrangler": "^4.81.0"
  }
}

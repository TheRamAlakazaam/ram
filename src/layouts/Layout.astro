---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { siteConfig } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string[];
  pageType?: "website" | "article" | "profile";
  publishDate?: Date;
  updatedDate?: Date;
}

const resolvedSiteUrl =
  Astro.site?.toString() ||
  import.meta.env.SITE_URL ||
  "https://theramalakazaam.com";
const appEnv = import.meta.env.APP_ENV || "development";
const allowIndexing = appEnv === "production";
const robotsContent = allowIndexing ? "index, follow" : "noindex, nofollow";

const {
  title,
  description = siteConfig.description,
  image = "/og.svg",
  keywords = siteConfig.keywords,
  pageType = "website",
  publishDate,
  updatedDate,
} = Astro.props;

const pageTitle = title
  ? `${title} | ${siteConfig.name}`
  : siteConfig.defaultTitle;
const canonical = new URL(Astro.url.pathname, resolvedSiteUrl).toString();
const socialImage = image.startsWith("http")
  ? image
  : new URL(image, resolvedSiteUrl).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: siteConfig.name,
      url: resolvedSiteUrl,
      description: siteConfig.description,
      inLanguage: "en-US",
    },
    {
      "@type": "Person",
      name: siteConfig.name,
      description: siteConfig.description,
      url: resolvedSiteUrl,
      homeLocation: siteConfig.location,
      knowsAbout: [...siteConfig.roles, ...siteConfig.tools],
    },
    ...(pageType === "article" && title
      ? [
          {
            "@type": "BlogPosting",
            headline: title,
            description,
            image: socialImage,
            mainEntityOfPage: canonical,
            datePublished: publishDate?.toISOString(),
            dateModified: (updatedDate || publishDate)?.toISOString(),
            author: {
              "@type": "Person",
              name: siteConfig.name,
            },
          },
        ]
      : []),
  ],
};
const serializedStructuredData = JSON.stringify(structuredData).replace(
  /</g,
  "\\u003c",
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="theme-color" content="#171717" />
    <meta name="msapplication-TileColor" content="#171717" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:type"
      content={pageType === "article" ? "article" : "website"}
    />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {
      publishDate && (
        <meta
          property="article:published_time"
          content={publishDate.toISOString()}
        />
      )
    }
    {
      updatedDate && (
        <meta
          property="article:modified_time"
          content={updatedDate.toISOString()}
        />
      )
    }
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      (() => {
        const storageKey = "ram-theme";
        try {
          const storedTheme = localStorage.getItem(storageKey);
          const preferredTheme = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches
            ? "dark"
            : "light";
          document.documentElement.dataset.theme =
            storedTheme === "dark" || storedTheme === "light"
              ? storedTheme
              : preferredTheme;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <script
      is:inline
      type="application/ld+json"
      set:html={serializedStructuredData}
    />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-shell">
      <SiteHeader />
      <main id="content" class="site-main">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #ffffff;
    --surface: #ffffff;
    --surface-strong: #f6f6f6;
    --ink: #111111;
    --ink-inverse: #ffffff;
    --muted: #666666;
    --line: rgba(17, 17, 17, 0.14);
    --line-strong: rgba(17, 17, 17, 0.42);
    --accent: #111111;
    --moss: #4d4d4d;
    --gold: #777777;
    --header-bg: rgba(255, 255, 255, 0.96);
    --pill-bg: rgba(53, 89, 74, 0.08);
    --photo-media-bg: #f0f0f0;
    --placeholder-bg: linear-gradient(135deg, #171717, #4d4d4d);
    --placeholder-ink: rgba(255, 255, 255, 0.92);
    --blockquote-line: rgba(178, 76, 42, 0.35);
    --shadow: none;
    --font-heading:
      "Inter", "Avenir Next", "Segoe UI", "Helvetica Neue", "Nimbus Sans",
      sans-serif;
    --font-main:
      "SFMono-Regular", "SF Mono", "Roboto Mono", "Cascadia Code",
      "IBM Plex Mono", "Fira Code", "Menlo", "Consolas", monospace;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --bg: #111111;
    --surface: #171717;
    --surface-strong: #202020;
    --ink: #f4f4f4;
    --ink-inverse: #111111;
    --muted: #b0b0b0;
    --line: rgba(255, 255, 255, 0.16);
    --line-strong: rgba(255, 255, 255, 0.42);
    --accent: #ffffff;
    --moss: #c7d8cf;
    --gold: #d5c68d;
    --header-bg: rgba(17, 17, 17, 0.96);
    --pill-bg: rgba(199, 216, 207, 0.1);
    --photo-media-bg: #202020;
    --placeholder-bg: linear-gradient(135deg, #111111, #333333);
    --placeholder-ink: rgba(255, 255, 255, 0.92);
    --blockquote-line: rgba(255, 255, 255, 0.32);
  }

  * {
    box-sizing: border-box;
  }

  html {
    margin: 0;
    min-height: 100%;
    scroll-behavior: smooth;
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    font-family: var(--font-main);
    font-size: 0.97rem;
    line-height: 1.6;
    background: var(--bg);
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: 0;
  }

  p {
    margin: 0;
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: -10rem;
    z-index: 30;
    padding: 0.75rem 1rem;
    background: var(--ink);
    color: var(--ink-inverse);
    border-radius: 8px;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 1rem;
  }

  .site-shell {
    display: flex;
    min-height: 100vh;
    min-height: 100dvh;
    flex-direction: column;
  }

  .frame {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
    background: var(--header-bg);
  }

  .site-header__inner,
  .site-footer__inner {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
  }

  .brand {
    display: inline-flex;
    text-decoration: none;
  }

  .brand__copy {
    display: grid;
  }

  .brand__copy strong {
    font-size: 1.05rem;
    letter-spacing: 0.03em;
  }

  .brand__copy small,
  .meta {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .nav-list {
    display: flex;
    column-gap: 1rem;
    row-gap: 0.35rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    list-style: none;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.25rem 0;
    text-decoration: none;
    color: var(--muted);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .theme-toggle {
    min-height: 2.25rem;
    padding: 0.25rem 0;
    border: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
  }

  .nav-link:hover,
  .nav-link.is-active,
  .theme-toggle:hover {
    color: var(--ink);
    background: transparent;
    transform: none;
  }

  .site-main {
    flex: 1 0 auto;
    padding: 1.2rem 0 1.5rem;
  }

  .panel,
  .card {
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: none;
    backdrop-filter: none;
  }

  .panel {
    border-radius: 8px;
    padding: clamp(1rem, 1.6vw, 1.45rem);
  }

  .card {
    border-radius: 8px;
    padding: 0.9rem;
    text-decoration: none;
    color: inherit;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .card:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    box-shadow: none;
  }

  .eyebrow {
    margin-bottom: 0.65rem;
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .lede {
    max-width: 60ch;
    color: var(--muted);
    font-size: clamp(1rem, 1.4vw, 1.12rem);
  }

  .button-row,
  .pill-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.65rem 0.95rem;
    border-radius: 8px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--ink-inverse);
    text-decoration: none;
    font-weight: 600;
  }

  .button.secondary {
    color: var(--ink);
    background: transparent;
    border-color: var(--line);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.7rem;
    border-radius: 8px;
    background: var(--pill-bg);
    color: var(--moss);
    font-size: 0.84rem;
  }

  .hero,
  .page-intro,
  .callout {
    display: grid;
    gap: 1rem;
  }

  .hero {
    grid-template-columns: 1.5fr 0.9fr;
    align-items: end;
  }

  .hero h1,
  .page-intro h1,
  .article-header h1 {
    font-size: clamp(1.9rem, 4vw, 3.25rem);
    max-width: 16ch;
  }

  .hero__copy {
    display: grid;
    gap: 0.9rem;
  }

  .hero__aside,
  .page-intro__aside {
    display: grid;
    gap: 0.75rem;
    align-self: stretch;
    padding: 1rem;
    border-radius: 8px;
    background: var(--surface-strong);
    border: 1px solid var(--line);
  }

  .stack-list {
    display: grid;
    gap: 0.85rem;
    color: var(--muted);
  }

  .section-block {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .section-head {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
  }

  .collection-root {
    display: grid;
    gap: 1rem;
  }

  .collection-toolbar {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 0.8rem;
  }

  .collection-search {
    position: relative;
    flex: 1 1 auto;
    display: flex;
    align-items: center;
  }

  .collection-search svg,
  .collection-sort svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .collection-search svg {
    position: absolute;
    left: 0.8rem;
    color: var(--muted);
    pointer-events: none;
  }

  .collection-search input {
    width: 100%;
    min-height: 2.6rem;
    padding: 0.65rem 0.8rem 0.65rem 2.4rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--ink);
    font: inherit;
  }

  .collection-search input::placeholder {
    color: var(--muted);
  }

  .collection-sort {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition:
      border-color 180ms ease,
      transform 180ms ease;
  }

  .collection-sort[data-sort-order="asc"] svg {
    transform: rotate(180deg);
  }

  .collection-sort:hover {
    border-color: var(--line-strong);
  }

  .collection-empty-state[hidden] {
    display: none;
  }

  .section-head h2 {
    font-size: clamp(1.45rem, 2.7vw, 2.1rem);
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
  }

  .section-grid > * {
    grid-column: span 6;
  }

  .section-grid--thirds > * {
    grid-column: span 4;
  }

  .feature-card {
    display: grid;
    gap: 0.85rem;
  }

  .feature-card h3,
  .entry-card h2,
  .photo-card h2 {
    font-size: 1.12rem;
  }

  .feature-card p,
  .entry-card p,
  .photo-card p,
  .footer-copy,
  .article-meta,
  .prose,
  .empty-state {
    color: var(--muted);
  }

  .entry-card,
  .photo-card {
    display: grid;
    gap: 0.75rem;
    align-content: space-between;
    min-height: 100%;
  }

  .photo-card {
    align-content: start;
    gap: 0;
    overflow: hidden;
    padding: 0;
  }

  .entry-card .eyebrow,
  .photo-card .eyebrow {
    margin-bottom: 0;
  }

  .entry-card__body,
  .photo-card__body {
    display: grid;
    gap: 0.55rem;
  }

  .photo-card__body {
    padding: 0.85rem 0.9rem 0.95rem;
  }

  .photo-card__head {
    display: grid;
    gap: 0.35rem;
  }

  .entry-card__footer,
  .photo-card__meta {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .entry-card__footer {
    padding-top: 0.75rem;
    margin-top: auto;
    border-top: 1px solid var(--line);
  }

  .photo-card__meta {
    justify-content: flex-start;
  }

  .photo-card__media {
    overflow: hidden;
    border-radius: 0;
    aspect-ratio: 4 / 3;
    min-height: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    background: var(--photo-media-bg);
  }

  .photo-card__media img,
  .photo-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-card__placeholder,
  .photo-hero__placeholder {
    position: relative;
    display: grid;
    place-items: end start;
    width: 100%;
    height: 100%;
    min-height: inherit;
    padding: 1rem;
    color: var(--placeholder-ink);
    background: var(--placeholder-bg);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    letter-spacing: 0.03em;
  }

  .article-shell {
    width: min(860px, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    gap: 0.85rem;
  }

  .article-header {
    display: grid;
    gap: 0.85rem;
  }

  .article-header--center {
    justify-items: center;
    text-align: center;
  }

  .article-header--center h1 {
    max-width: 100%;
  }

  .article-header--center .article-meta {
    justify-content: center;
  }

  .article-meta {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .article-content {
    padding: clamp(1rem, 1.6vw, 1.7rem);
  }

  .prose {
    display: grid;
    gap: 1rem;
    font-size: 1rem;
  }

  .prose > * {
    width: min(100%, 68ch);
    margin-inline: auto;
  }

  .prose h2,
  .prose h3 {
    margin-top: 0.75rem;
    font-size: 1.45rem;
  }

  .prose p,
  .prose li {
    max-width: none;
  }

  .prose a {
    color: var(--accent);
  }

  .prose blockquote {
    margin: 0;
    padding-left: 1rem;
    border-left: 3px solid var(--blockquote-line);
    color: var(--ink);
    font-family: var(--font-heading);
    font-size: 1.08rem;
  }

  .photo-hero {
    overflow: hidden;
    border-radius: 8px;
    min-height: 360px;
    border: 1px solid var(--line);
    background: var(--surface-strong);
  }

  .photo-hero__placeholder {
    min-height: 360px;
  }

  .callout {
    align-items: center;
    grid-template-columns: 1.2fr 0.8fr;
  }

  .site-footer {
    margin-top: 0.75rem;
    border-top: 1px solid var(--line);
    background: transparent;
  }

  .footer-meta {
    display: grid;
    gap: 0.35rem;
    text-align: right;
    color: var(--muted);
  }

  .empty-state {
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px dashed var(--line);
  }

  .reveal {
    animation: rise-in 700ms ease both;
  }

  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .hero,
    .page-intro,
    .callout {
      grid-template-columns: 1fr;
    }

    .section-grid > *,
    .section-grid--thirds > * {
      grid-column: 1 / -1;
    }

    .site-header__inner,
    .site-footer__inner,
    .section-head,
    .article-meta,
    .collection-toolbar {
      align-items: start;
      flex-direction: column;
    }

    .nav-list {
      justify-content: flex-start;
    }

    .hero h1,
    .page-intro h1,
    .article-header h1 {
      max-width: 100%;
    }

    .footer-meta {
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .site-main {
      padding-top: 1rem;
    }

    .frame,
    .article-shell {
      width: min(100% - 1rem, 1120px);
    }

    .panel,
    .card {
      border-radius: 8px;
    }

    .site-header__inner,
    .site-footer__inner {
      gap: 0.85rem;
    }

    .nav-list {
      column-gap: 0.85rem;
      row-gap: 0.15rem;
    }

    .nav-link {
      min-height: 1.8rem;
      font-size: 0.9rem;
    }
  }
</style>

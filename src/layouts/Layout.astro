---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { siteConfig } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  keywords?: string[];
  pageType?: "website" | "article" | "profile";
  structuredType?: "BlogPosting" | "ImageGallery";
  publishDate?: Date;
  updatedDate?: Date;
}

const resolvedSiteUrl =
  Astro.site?.toString() ||
  import.meta.env.SITE_URL ||
  "https://theramalakazaam.com";
const appEnv = import.meta.env.APP_ENV || "development";
const allowIndexing = appEnv === "production";
const robotsContent = allowIndexing
  ? "index, follow, max-image-preview:large"
  : "noindex, nofollow";

const {
  title,
  description = siteConfig.description,
  image = siteConfig.defaultSocialImage || "/og.png",
  keywords = siteConfig.keywords,
  pageType = "website",
  structuredType = "BlogPosting",
  publishDate,
  updatedDate,
} = Astro.props;

const pageTitle = title
  ? `${title} | ${siteConfig.name}`
  : siteConfig.defaultTitle;
const canonical = new URL(Astro.url.pathname, resolvedSiteUrl).toString();
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/**/*.{avif,gif,jpeg,jpg,png,webp}",
);
const imageKey = image.startsWith("src/") ? `/${image}` : image;
const imageImport = images[imageKey];
const importedSocialImage = imageImport
  ? (await imageImport()).default
  : undefined;
const optimizedSocialImage = importedSocialImage
  ? await getImage({ src: importedSocialImage, width: 1200, format: "webp" })
  : undefined;
const socialImageSource = optimizedSocialImage?.src || image;
const socialImage = socialImageSource.startsWith("http")
  ? socialImageSource
  : new URL(socialImageSource, resolvedSiteUrl).toString();
const socialImageAlt = `${pageTitle} social preview`;
const sameAs = [
  siteConfig.social.instagram,
  siteConfig.social.linkedin,
  siteConfig.social.github,
].filter(Boolean);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": new URL("#website", resolvedSiteUrl).toString(),
      name: siteConfig.name,
      url: resolvedSiteUrl,
      description: siteConfig.description,
      inLanguage: "en-US",
    },
    {
      "@type": "Person",
      "@id": new URL("#person", resolvedSiteUrl).toString(),
      name: siteConfig.name,
      description: siteConfig.description,
      url: resolvedSiteUrl,
      homeLocation: siteConfig.location,
      knowsAbout: [...siteConfig.roles, ...siteConfig.tools],
      sameAs,
    },
    {
      "@type": "WebPage",
      "@id": canonical,
      url: canonical,
      name: pageTitle,
      description,
      isPartOf: {
        "@id": new URL("#website", resolvedSiteUrl).toString(),
      },
      about: {
        "@id": new URL("#person", resolvedSiteUrl).toString(),
      },
      inLanguage: "en-US",
    },
    ...(pageType === "article" && title
      ? [
          {
            "@type": structuredType,
            "@id": `${canonical}#article`,
            headline: title,
            description,
            image: socialImage,
            mainEntityOfPage: canonical,
            datePublished: publishDate?.toISOString(),
            dateModified: (updatedDate || publishDate)?.toISOString(),
            keywords: keywords.join(", "),
            author: {
              "@type": "Person",
              "@id": new URL("#person", resolvedSiteUrl).toString(),
            },
          },
        ]
      : []),
  ],
};
const serializedStructuredData = JSON.stringify(structuredData).replace(
  /</g,
  "\\u003c",
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="theme-color" content="#171717" />
    <meta name="msapplication-TileColor" content="#171717" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:type"
      content={pageType === "article"
        ? "article"
        : pageType === "profile"
          ? "profile"
          : "website"}
    />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    {
      publishDate && (
        <meta
          property="article:published_time"
          content={publishDate.toISOString()}
        />
      )
    }
    {
      updatedDate && (
        <meta
          property="article:modified_time"
          content={updatedDate.toISOString()}
        />
      )
    }
    {
      pageType === "article" &&
        keywords.map((keyword) => (
          <meta property="article:tag" content={keyword} />
        ))
    }
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      (() => {
        const storageKey = "ram-theme";
        try {
          const storedTheme = localStorage.getItem(storageKey);
          const preferredTheme = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches
            ? "dark"
            : "light";
          document.documentElement.dataset.theme =
            storedTheme === "dark" || storedTheme === "light"
              ? storedTheme
              : preferredTheme;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <script
      is:inline
      type="application/ld+json"
      set:html={serializedStructuredData}
    />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-shell">
      <SiteHeader />
      <main id="content" class="site-main">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #ffffff;
    --surface: #ffffff;
    --surface-strong: #f6f6f6;
    --ink: #111111;
    --ink-inverse: #ffffff;
    --muted: #666666;
    --line: rgba(17, 17, 17, 0.14);
    --line-strong: rgba(17, 17, 17, 0.42);
    --accent: #111111;
    --moss: #4d4d4d;
    --gold: #777777;
    --header-bg: rgba(255, 255, 255, 0.96);
    --pill-bg: rgba(53, 89, 74, 0.08);
    --photo-media-bg: #f0f0f0;
    --placeholder-bg: linear-gradient(135deg, #171717, #4d4d4d);
    --placeholder-ink: rgba(255, 255, 255, 0.92);
    --blockquote-line: rgba(178, 76, 42, 0.35);
    --shadow: none;
    --page-max: 1120px;
    --article-max: 860px;
    --page-gutter: clamp(1rem, 3.5vw, 2.5rem);
    --section-gap: clamp(1.4rem, 3vw, 2.35rem);
    --panel-padding: clamp(1rem, 2vw, 1.5rem);
    --content-gap: 1rem;
    --divider-padding: 0.9rem;
    --item-padding: 1rem 0;
    --control-padding: 0.65rem 0.8rem;
    --font-heading:
      "Inter", "Avenir Next", "Segoe UI", "Helvetica Neue", "Nimbus Sans",
      sans-serif;
    --font-main:
      "SFMono-Regular", "SF Mono", "Roboto Mono", "Cascadia Code",
      "IBM Plex Mono", "Fira Code", "Menlo", "Consolas", monospace;
    --font-body:
      "Source Sans 3", "Aptos", "Segoe UI", "Inter", "Helvetica Neue", Arial,
      sans-serif;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --bg: #111111;
    --surface: #171717;
    --surface-strong: #202020;
    --ink: #f4f4f4;
    --ink-inverse: #111111;
    --muted: #b0b0b0;
    --line: rgba(255, 255, 255, 0.16);
    --line-strong: rgba(255, 255, 255, 0.42);
    --accent: #ffffff;
    --moss: #c7d8cf;
    --gold: #d5c68d;
    --header-bg: rgba(17, 17, 17, 0.96);
    --pill-bg: rgba(199, 216, 207, 0.1);
    --photo-media-bg: #202020;
    --placeholder-bg: linear-gradient(135deg, #111111, #333333);
    --placeholder-ink: rgba(255, 255, 255, 0.92);
    --blockquote-line: rgba(255, 255, 255, 0.32);
  }

  * {
    box-sizing: border-box;
  }

  html {
    margin: 0;
    min-height: 100%;
    scroll-behavior: smooth;
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.68;
    background: var(--bg);
  }

  body[data-nav-open="true"] {
    overflow: hidden;
  }

  body[data-spotlight-open="true"] {
    overflow: hidden;
  }

  a {
    color: inherit;
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  textarea:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 3px;
  }

  img {
    display: block;
    max-width: 100%;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    font-family: var(--font-main);
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: 0;
    text-wrap: balance;
  }

  p {
    margin: 0;
    text-wrap: pretty;
  }

  ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: -10rem;
    z-index: 30;
    padding: 0.75rem 1rem;
    background: var(--ink);
    color: var(--ink-inverse);
    border-radius: 8px;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 1rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .site-shell {
    display: flex;
    min-height: 100vh;
    min-height: 100dvh;
    flex-direction: column;
  }

  .frame {
    width: min(
      var(--page-max),
      calc(100% - var(--page-gutter) - var(--page-gutter))
    );
    margin: 0 auto;
  }

  .site-header {
    position: relative;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: var(--header-bg);
  }

  .site-header__inner {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
  }

  .site-header nav {
    min-width: 0;
  }

  .site-header__actions {
    display: inline-flex;
    gap: 0.45rem;
    align-items: center;
    justify-content: flex-end;
  }

  .site-footer__inner {
    display: grid;
    gap: 0.65rem;
    justify-items: center;
    padding: 1rem 0;
    text-align: center;
  }

  .brand {
    display: inline-flex;
    text-decoration: none;
  }

  .brand__copy {
    display: grid;
  }

  .brand__copy strong {
    font-family: var(--font-main);
    font-size: 1.05rem;
    letter-spacing: 0.03em;
  }

  .brand__copy small,
  .meta {
    color: var(--muted);
    font-family: var(--font-main);
    font-size: 0.92rem;
  }

  .nav-list {
    display: flex;
    column-gap: 1rem;
    row-gap: 0.35rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    list-style: none;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.25rem 0;
    text-decoration: none;
    color: var(--muted);
    font-family: var(--font-main);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
  }

  .mobile-nav-toggle {
    display: none;
    position: relative;
    width: 2.35rem;
    height: 2.35rem;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
  }

  .mobile-nav-toggle span,
  .mobile-nav-toggle span::before,
  .mobile-nav-toggle span::after {
    position: absolute;
    left: 50%;
    width: 1.05rem;
    height: 1px;
    background: currentColor;
    content: "";
    transform: translateX(-50%);
    transition:
      top 180ms ease,
      transform 180ms ease,
      opacity 180ms ease;
  }

  .mobile-nav-toggle span {
    top: 50%;
  }

  .mobile-nav-toggle span::before {
    top: -0.38rem;
  }

  .mobile-nav-toggle span::after {
    top: 0.38rem;
  }

  .site-header[data-nav-open="true"] .mobile-nav-toggle span {
    transform: translateX(-50%) rotate(45deg);
  }

  .site-header[data-nav-open="true"] .mobile-nav-toggle span::before {
    top: 0;
    opacity: 0;
  }

  .site-header[data-nav-open="true"] .mobile-nav-toggle span::after {
    top: 0;
    transform: translateX(-50%) rotate(-90deg);
  }

  .mobile-drawer[hidden] {
    display: none;
  }

  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 19;
    display: grid;
    place-items: center;
    min-height: 100vh;
    min-height: 100dvh;
    padding: 5.75rem var(--page-gutter) 2.5rem;
    background: var(--bg);
    text-align: center;
  }

  .mobile-drawer nav {
    display: grid;
    gap: 1.25rem;
    width: min(100%, 24rem);
  }

  .mobile-drawer__title {
    color: var(--ink);
    font-family: var(--font-main);
    font-size: clamp(1.25rem, 6vw, 1.75rem);
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .mobile-drawer__list {
    display: grid;
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .mobile-drawer__link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 4.2rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    font-family: var(--font-main);
    font-size: clamp(1.05rem, 5vw, 1.35rem);
    letter-spacing: 0.03em;
    text-decoration: none;
  }

  .theme-toggle__icon {
    width: 1.1rem;
    height: 1.1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .theme-toggle__icon--sun {
    display: none;
  }

  :root[data-theme="dark"] .theme-toggle__icon--sun {
    display: block;
  }

  :root[data-theme="dark"] .theme-toggle__icon--moon {
    display: none;
  }

  .nav-link:hover,
  .nav-link.is-active,
  .theme-toggle:hover,
  .mobile-nav-toggle:hover,
  .mobile-drawer__link:hover,
  .mobile-drawer__link.is-active {
    color: var(--ink);
    background: transparent;
    transform: none;
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible,
  .mobile-nav-toggle:hover,
  .mobile-nav-toggle:focus-visible {
    border-color: var(--line-strong);
  }

  .site-main {
    flex: 1 0 auto;
    padding: clamp(1.1rem, 3vw, 2.35rem) 0 clamp(2rem, 4vw, 3.25rem);
  }

  .panel,
  .card {
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow);
    backdrop-filter: none;
  }

  .panel {
    border-radius: 8px;
    padding: var(--panel-padding);
  }

  .card {
    border-radius: 8px;
    padding: clamp(0.85rem, 1.5vw, 1rem);
    text-decoration: none;
    color: inherit;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .card:hover,
  .card:focus-visible {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    box-shadow: none;
  }

  .eyebrow {
    margin-bottom: 0.65rem;
    color: var(--accent);
    font-family: var(--font-main);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .lede {
    max-width: 60ch;
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 1.08rem;
  }

  .button-row,
  .pill-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    padding: 0.65rem 0.95rem;
    border-radius: 8px;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--ink-inverse);
    font-family: var(--font-main);
    text-decoration: none;
    font-weight: 600;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .button.secondary {
    color: var(--ink);
    background: transparent;
    border-color: var(--line);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.7rem;
    border-radius: 8px;
    background: var(--pill-bg);
    color: var(--moss);
    font-family: var(--font-main);
    font-size: 0.84rem;
  }

  .hero,
  .page-intro,
  .callout {
    display: grid;
    gap: var(--content-gap);
  }

  .hero {
    grid-template-columns: 1.5fr 0.9fr;
    align-items: end;
  }

  .hero h1,
  .page-intro h1,
  .article-header h1 {
    font-size: 3.15rem;
    max-width: 16ch;
  }

  .page-intro--minimal {
    padding-bottom: var(--divider-padding);
    border-bottom: 1px solid var(--line);
  }

  .page-intro--minimal .eyebrow {
    margin-bottom: 0;
  }

  .hero__copy {
    display: grid;
    gap: var(--content-gap);
  }

  .hero__aside,
  .page-intro__aside {
    display: grid;
    gap: 0.75rem;
    align-self: stretch;
    padding: var(--panel-padding);
    border-radius: 8px;
    background: var(--surface-strong);
    border: 1px solid var(--line);
  }

  .stack-list {
    display: grid;
    gap: 0.85rem;
    color: var(--muted);
  }

  .section-block {
    display: grid;
    gap: clamp(0.85rem, 1.5vw, 1.1rem);
    margin-top: var(--section-gap);
  }

  .section-head {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .section-head .eyebrow {
    margin-bottom: 0;
  }

  .page-kicker-header {
    display: grid;
    gap: 0.65rem;
    padding-bottom: var(--divider-padding);
    border-bottom: 1px solid var(--line);
  }

  .page-kicker-header .eyebrow {
    margin-bottom: 0;
  }

  .collection-root {
    display: grid;
    gap: var(--content-gap);
  }

  .collection-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    padding: var(--control-padding);
  }

  .collection-search {
    position: relative;
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .collection-search svg,
  .collection-sort svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .collection-search svg {
    position: absolute;
    left: 0.8rem;
    color: var(--muted);
    pointer-events: none;
  }

  .collection-search input {
    width: 100%;
    min-height: 2.6rem;
    padding: 0.65rem 0.8rem 0.65rem 2.4rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--ink);
    font: inherit;
  }

  .collection-search input::placeholder {
    color: var(--muted);
  }

  .collection-sort {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition:
      border-color 180ms ease,
      transform 180ms ease;
  }

  .collection-sort[data-sort-order="asc"] svg {
    transform: rotate(180deg);
  }

  .collection-sort:hover {
    border-color: var(--line-strong);
  }

  .collection-empty-state[hidden] {
    display: none;
  }

  .section-head h2 {
    font-size: 2rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(0.85rem, 1.6vw, 1.1rem);
  }

  .section-grid > * {
    grid-column: span 6;
  }

  .section-grid--thirds > * {
    grid-column: span 4;
  }


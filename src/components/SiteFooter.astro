---
import { pageCopy, siteConfig } from "@/data/site";
import { safeHref } from "@/utils/url";

const year = new Date().getFullYear();
const instagramHref = safeHref(siteConfig.social.instagram);
const linkedinHref = safeHref(siteConfig.social.linkedin);
const githubHref = safeHref(siteConfig.social.github);
const socialLinks = [
  {
    href: instagramHref,
    label: pageCopy.footer.instagramAriaLabel,
    icon: "instagram",
  },
  {
    href: linkedinHref,
    label: pageCopy.footer.linkedinAriaLabel,
    icon: "linkedin",
  },
  {
    href: githubHref,
    label: pageCopy.footer.githubAriaLabel,
    icon: "github",
  },
].filter((item) => item.href !== "#");
---

<footer class="site-footer">
  <div class="frame site-footer__inner">
    <p>{siteConfig.name} &copy; {year}</p>

    {
      socialLinks.length > 0 && (
        <div class="footer-social" aria-label={pageCopy.footer.socialAriaLabel}>
          {socialLinks.map((item) => (
            <a href={item.href} aria-label={item.label} rel="me">
              {item.icon === "instagram" && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1" />
                </svg>
              )}
              {item.icon === "linkedin" && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6.5 10v8" />
                  <path d="M6.5 7v.01" />
                  <path d="M11 18v-8" />
                  <path d="M11 13.5c0-2 1.2-3.5 3.4-3.5 2 0 3.1 1.3 3.1 3.7V18" />
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                </svg>
              )}
              {item.icon === "github" && (
                <svg class="icon-fill" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2C6.48 2 2 6.58 2 12.22c0 4.5 2.87 8.31 6.84 9.66.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.88-2.78.62-3.37-1.2-3.37-1.2-.46-1.2-1.11-1.51-1.11-1.51-.91-.64.07-.63.07-.63 1 .08 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.74 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.99c.85 0 1.71.12 2.51.36 1.91-1.33 2.75-1.05 2.75-1.05.55 1.43.2 2.48.1 2.74.64.72 1.03 1.63 1.03 2.75 0 3.95-2.35 4.82-4.59 5.08.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.23 10.23 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z" />
                </svg>
              )}
            </a>
          ))}
        </div>
      )
    }
  </div>
</footer>

<style>
  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--ink);
  }

  .footer-social svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .footer-social svg.icon-fill {
    fill: currentColor;
    stroke: none;
  }
</style>

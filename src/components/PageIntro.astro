---
interface Props {
  eyebrow?: string;
  title?: string;
  lede?: string;
}

const { eyebrow, title, lede } = Astro.props;
const hasAside = Astro.slots.has("default");
const isMinimal = !title && !lede && !hasAside;
const classes = [
  "page-intro",
  "reveal",
  isMinimal ? "page-intro--minimal" : "panel",
].join(" ");
---

<section class={classes}>
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    {title && <h1>{title}</h1>}
    {lede && <p class="lede">{lede}</p>}
  </div>

  {
    hasAside && (
      <div class="page-intro__aside">
        <slot />
      </div>
    )
  }
</section>

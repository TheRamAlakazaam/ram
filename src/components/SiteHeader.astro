---
import { pageCopy, siteConfig } from "@/data/site";

const pathname = Astro.url.pathname;
const themeToggleCopy = pageCopy.header.themeToggle;
---

<header class="site-header">
  <div class="frame site-header__inner">
    <a class="brand" href="/">
      <span class="brand__copy">
        <strong>{siteConfig.name}</strong>
      </span>
    </a>

    <nav aria-label={pageCopy.header.navigationAriaLabel}>
      <ul class="nav-list">
        {
          siteConfig.navigation.map((item) => {
            const isActive =
              item.href === "/"
                ? pathname === "/"
                : pathname.startsWith(item.href);

            return (
              <li>
                <a
                  class:list={["nav-link", { "is-active": isActive }]}
                  href={item.href}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <button
      class="theme-toggle"
      type="button"
      data-theme-toggle
      data-dark-label={themeToggleCopy.darkLabel}
      data-light-label={themeToggleCopy.lightLabel}
      data-switch-to-dark-aria-label={themeToggleCopy.switchToDarkAriaLabel}
      data-switch-to-light-aria-label={themeToggleCopy.switchToLightAriaLabel}
      aria-label={themeToggleCopy.switchToDarkAriaLabel}
      aria-pressed="false"
    >
      <span data-theme-toggle-label>{themeToggleCopy.darkLabel}</span>
    </button>
  </div>
</header>

<script is:inline>
  (() => {
    const storageKey = "ram-theme";
    const root = document.documentElement;
    const button = document.querySelector("[data-theme-toggle]");
    const label = button?.querySelector("[data-theme-toggle-label]");

    const applyTheme = (theme) => {
      const darkLabel = button?.dataset.darkLabel || "Dark";
      const lightLabel = button?.dataset.lightLabel || "Light";
      const switchToDarkAriaLabel =
        button?.dataset.switchToDarkAriaLabel || "Switch to dark mode";
      const switchToLightAriaLabel =
        button?.dataset.switchToLightAriaLabel || "Switch to light mode";
      root.dataset.theme = theme;
      const isDark = theme === "dark";
      button?.setAttribute(
        "aria-label",
        isDark ? switchToLightAriaLabel : switchToDarkAriaLabel,
      );
      button?.setAttribute("aria-pressed", String(isDark));
      if (label) {
        label.textContent = isDark ? lightLabel : darkLabel;
      }
    };

    const getInitialTheme = () => {
      try {
        const storedTheme = localStorage.getItem(storageKey);
        return storedTheme === "dark" || storedTheme === "light"
          ? storedTheme
          : root.dataset.theme || "light";
      } catch {
        return root.dataset.theme || "light";
      }
    };

    applyTheme(getInitialTheme());

    button?.addEventListener("click", () => {
      const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
      try {
        localStorage.setItem(storageKey, nextTheme);
      } catch {
        // The visible theme can still change when storage is unavailable.
      }
      applyTheme(nextTheme);
    });
  })();
</script>

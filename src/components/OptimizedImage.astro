---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

interface Props {
  src: string;
  alt: string;
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  sizes?: string;
  widths?: number[];
}

const {
  src,
  alt,
  loading = "lazy",
  decoding = "async",
  fetchpriority,
  sizes = "(min-width: 900px) 33vw, 100vw",
  widths = [360, 540, 720, 960, 1200],
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/**/*.{avif,gif,jpeg,jpg,png,webp}",
);
const imageKey = src.startsWith("src/") ? `/${src}` : src;
const imageImport = images[imageKey];
const shouldRenderPlainImage = src.startsWith("/") || /^https?:\/\//.test(src);

const importedImage = imageImport ? (await imageImport()).default : undefined;
const sortedWidths = [...new Set(widths)]
  .filter((width) => Number.isFinite(width) && width > 0)
  .sort((a, b) => a - b);
const imageWidths =
  importedImage && sortedWidths.length > 0
    ? sortedWidths.filter((width) => width <= importedImage.width)
    : sortedWidths;
const responsiveWidths =
  importedImage && imageWidths.length > 0 ? imageWidths : sortedWidths;
const generatedImages = importedImage
  ? await Promise.all(
      responsiveWidths.map((width) =>
        getImage({ src: importedImage, width, format: "webp" }),
      ),
    )
  : [];
const fallbackImage = generatedImages.at(-1);
const fallbackWidth =
  fallbackImage && responsiveWidths.length > 0
    ? responsiveWidths[responsiveWidths.length - 1]
    : importedImage?.width;
const fallbackHeight =
  importedImage && fallbackWidth
    ? Math.round((fallbackWidth / importedImage.width) * importedImage.height)
    : importedImage?.height;
const srcset = generatedImages
  .map((image, index) => `${image.src} ${responsiveWidths[index]}w`)
  .join(", ");
---

{
  fallbackImage ? (
    <img
      src={fallbackImage.src}
      srcset={srcset}
      sizes={sizes}
      width={fallbackWidth}
      height={fallbackHeight}
      alt={alt}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
    />
  ) : (
    shouldRenderPlainImage && (
      <img
        src={src}
        alt={alt}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    )
  )
}

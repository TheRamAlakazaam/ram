---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  src: string;
  alt: string;
  loading?: "eager" | "lazy";
  sizes?: string;
  widths?: number[];
}

const {
  src,
  alt,
  loading = "lazy",
  sizes = "(min-width: 900px) 33vw, 100vw",
  widths = [360, 540, 720, 960, 1200],
} = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/**/*.{avif,gif,jpeg,jpg,png,webp}",
);
const imageKey = src.startsWith("src/") ? `/${src}` : src;
const imageImport = images[imageKey];
const shouldRenderPlainImage = src.startsWith("/") || /^https?:\/\//.test(src);
---

{
  imageImport ? (
    <Image
      src={imageImport()}
      alt={alt}
      loading={loading}
      decoding="async"
      widths={widths}
      sizes={sizes}
    />
  ) : (
    shouldRenderPlainImage && (
      <img src={src} alt={alt} loading={loading} decoding="async" />
    )
  )
}

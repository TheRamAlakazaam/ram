---
import OptimizedImage from "@/components/OptimizedImage.astro";
import { formatDate } from "@/utils/content";
import { formatAlbumImageCount } from "@/utils/photography";

interface Props {
  href: string;
  title: string;
  description: string;
  publishDate: Date;
  location: string;
  alt: string;
  image?: string;
  imageCount?: number;
  showDescription?: boolean;
  showImageCount?: boolean;
  sizes?: string;
}

const {
  href,
  title,
  description,
  publishDate,
  location,
  alt,
  image,
  imageCount,
  showDescription = true,
  showImageCount = true,
  sizes = "(min-width: 900px) 33vw, 100vw",
} = Astro.props;

const shouldShowDescription = showDescription && description.trim().length > 0;
---

<a
  class:list={[
    "card",
    "photo-card",
    "reveal",
    { "photo-card--compact": !shouldShowDescription },
  ]}
  href={href}
>
  <div class="photo-card__media">
    {
      image ? (
        <OptimizedImage src={image} alt={alt} sizes={sizes} />
      ) : (
        <div class="photo-card__placeholder">
          <span>{location}</span>
        </div>
      )
    }
  </div>

  <div class="photo-card__body">
    <div class="photo-card__head">
      <h2>{title}</h2>
      <div class="photo-card__meta">
        <span class="meta">{location}</span>
        <span class="meta">{formatDate(publishDate)}</span>
        {
          showImageCount &&
            typeof imageCount === "number" &&
            imageCount > 0 && (
              <span class="meta">{formatAlbumImageCount(imageCount)}</span>
            )
        }
      </div>
    </div>

    {shouldShowDescription && <p>{description}</p>}
  </div>
</a>

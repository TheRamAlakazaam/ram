---
import { getCollection } from "astro:content";

import OptimizedImage from "@/components/OptimizedImage.astro";
import { pageCopy, siteConfig } from "@/data/site";
import Layout from "@/layouts/Layout.astro";
import { formatDate, sortByDateDesc } from "@/utils/content";
import { getAlbumGallery } from "@/utils/photography";

const writing = sortByDateDesc(await getCollection("blog"));
const photos = sortByDateDesc(await getCollection("photos"));

const latestPictures = photos
  .flatMap((photo) =>
    getAlbumGallery(photo.data).map((image) => ({
      image,
      href: `/photography/${photo.slug}`,
      title: photo.data.title,
      location: photo.data.location,
    })),
  )
  .slice(0, 4);
const latestWriting = writing.slice(0, 4);
const homeCopy = pageCopy.home;
const heroSummary =
  siteConfig.summary
    .replace(/^Raul Martinez is a\s+/i, "A ")
    .split(". ")
    .filter(Boolean)[0] || siteConfig.description;
const homeDescription = `${heroSummary}. ${homeCopy.seoDescription}`;
---

<Layout description={homeDescription} keywords={siteConfig.keywords}>
  <div class="frame home-frame">
    <section class="home-hero">
      <div class="home-hero__copy reveal">
        <h1>{homeCopy.heroTitle}</h1>
        <p class="home-deck">{heroSummary}</p>
      </div>
    </section>

    <section class="home-section reveal">
      <div class="home-panel">
        <div class="home-section__head">
          <div>
            <h2>{homeCopy.photosTitle}</h2>
          </div>
          <a class="home-section__link" href="/photography">
            {homeCopy.photosCtaLabel}
          </a>
        </div>
        {
          latestPictures.length > 0 ? (
            <div class="home-photo-grid">
              {latestPictures.map((picture, index) => (
                <a class="home-photo-tile" href={picture.href}>
                  <OptimizedImage
                    src={picture.image}
                    alt=""
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : undefined}
                    sizes="(min-width: 1120px) 260px, (min-width: 900px) 25vw, (min-width: 640px) 50vw, 100vw"
                    widths={[240, 360, 520, 720]}
                  />
                  <span>
                    <strong>{picture.title}</strong>
                    <span>{picture.location}</span>
                  </span>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty-state">{pageCopy.photography.emptyState}</p>
          )
        }
      </div>
    </section>

    <section class="home-section reveal">
      <div class="home-panel">
        <div class="home-section__head">
          <div>
            <h2>{homeCopy.writingTitle}</h2>
          </div>
          <a class="home-section__link" href="/blog">
            {homeCopy.writingCtaLabel}
          </a>
        </div>
        <div class="home-blog-list">
          {
            latestWriting.map((post) => (
              <a class="home-blog-card" href={`/blog/${post.slug}`}>
                <span class="home-blog-card__date meta">
                  {formatDate(post.data.publishDate)}
                </span>
                <div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div
                      class="pill-row"
                      aria-label={pageCopy.shared.tagsAriaLabel}
                    >
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="pill">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="home-contact reveal">
      <h2>{homeCopy.contactTitle}</h2>
      <a class="button" href="/contact">{homeCopy.contactCtaLabel}</a>
    </section>
  </div>
</Layout>

<style>
  .home-frame {
    display: grid;
    gap: var(--section-gap);
  }

  .home-hero {
    display: grid;
    padding-bottom: var(--divider-padding);
    border-bottom: 1px solid var(--line);
  }

  .home-hero h1 {
    max-width: none;
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    line-height: 1.05;
    white-space: nowrap;
  }

  .home-hero__copy {
    display: grid;
    gap: var(--content-gap);
    max-width: 72rem;
  }

  .home-deck {
    max-width: 62ch;
    color: var(--muted);
    font-size: clamp(1rem, 1.2vw, 1.12rem);
  }

  .home-panel {
    display: grid;
    gap: var(--content-gap);
  }

  .home-section {
    padding: var(--panel-padding);
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .home-section__head {
    display: flex;
    align-items: end;
    gap: 1rem;
    justify-content: space-between;
    min-width: 0;
    padding-bottom: 0;
  }

  .home-section__head h2 {
    font-size: 1.02rem;
    letter-spacing: 0.03em;
  }

  .home-section__link {
    color: var(--muted);
    font-family: var(--font-main);
    font-size: 0.86rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .home-section__link:hover,
  .home-section__link:focus-visible {
    color: var(--ink);
  }

  .home-photo-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--content-gap);
    padding-top: var(--divider-padding);
    border-top: 1px solid var(--line);
  }

  .home-photo-tile {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    min-height: 0;
    border-radius: 8px;
    background: var(--photo-media-bg);
    text-decoration: none;
  }

  .home-photo-tile :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .home-photo-tile:hover :global(img),
  .home-photo-tile:focus-visible :global(img) {
    transform: scale(1.025);
  }

  .home-photo-tile > span {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    gap: 0.1rem;
    padding: 0.65rem;
    color: #ffffff;
    background: linear-gradient(
      to top,
      rgba(17, 17, 17, 0.72),
      rgba(17, 17, 17, 0)
    );
  }

  .home-photo-tile strong {
    font-family: var(--font-main);
    font-size: 0.95rem;
    line-height: 1.1;
  }

  .home-photo-tile span span {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.82rem;
  }

  .home-blog-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .home-blog-card {
    display: grid;
    grid-template-columns: minmax(8rem, 0.24fr) minmax(0, 1fr);
    gap: 1.25rem;
    align-items: start;
    padding: var(--item-padding);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    transition:
      transform 180ms ease,
      color 180ms ease,
      border-color 180ms ease;
  }

  .home-blog-card:hover,
  .home-blog-card:focus-visible {
    color: var(--accent);
    border-color: var(--line-strong);
    transform: translateX(0.25rem);
  }

  .home-blog-card h3 {
    max-width: 100%;
    font-size: 1.2rem;
  }

  .home-blog-card p {
    max-width: 72ch;
    margin-top: 0.55rem;
    color: var(--muted);
  }

  .home-blog-card .pill-row {
    margin-top: 0.7rem;
  }

  .home-contact {
    display: grid;
    gap: 0.65rem;
    justify-items: center;
    padding-top: 0.25rem;
    text-align: center;
  }

  .home-contact h2 {
    font-size: clamp(1.25rem, 2.3vw, 1.8rem);
  }

  @media (max-width: 900px) {
    .home-photo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-frame {
      gap: 1.2rem;
    }

    .home-photo-tile > span {
      padding: 0.8rem;
    }

    .home-section__head {
      align-items: start;
      flex-direction: column;
    }

    .home-blog-card {
      grid-template-columns: 1fr;
    }

    .home-blog-card h3 {
      font-size: 1.08rem;
    }

    .home-photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

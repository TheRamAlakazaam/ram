---
import { getCollection } from "astro:content";

import OptimizedImage from "@/components/OptimizedImage.astro";
import { pageCopy, siteConfig } from "@/data/site";
import Layout from "@/layouts/Layout.astro";
import { formatDate, sortByDateDesc } from "@/utils/content";
import { getAlbumCoverAlt, getAlbumGallery } from "@/utils/photography";

const writing = sortByDateDesc(await getCollection("blog"));
const photos = sortByDateDesc(await getCollection("photos"));

const latestPictures = photos
  .flatMap((photo) =>
    getAlbumGallery(photo.data).map((image, index) => ({
      image,
      href: `/photography/${photo.slug}`,
      alt:
        index === 0
          ? getAlbumCoverAlt(photo.data)
          : `${photo.data.title} photograph ${index + 1}`,
      title: photo.data.title,
      location: photo.data.location,
    })),
  )
  .slice(0, 4);
const latestWriting = writing.slice(0, 4);
const homeCopy = pageCopy.home;
const heroSummary =
  siteConfig.summary
    .replace(/^Raul Martinez is a\s+/i, "A ")
    .split(". ")
    .filter(Boolean)[0] || siteConfig.description;
const homeDescription = `${heroSummary}. ${homeCopy.seoDescription}`;
---

<Layout description={homeDescription} keywords={siteConfig.keywords}>
  <div class="frame home-frame">
    <section class="home-hero">
      <div class="home-hero__copy reveal">
        <p class="eyebrow">{siteConfig.location}</p>
        <h1>{homeCopy.heroTitle}</h1>
        <p class="home-deck">{heroSummary}</p>
      </div>
    </section>

    <section class="home-section reveal">
      <div class="home-panel">
        <div class="home-section__head">
          <h2>{homeCopy.photosTitle}</h2>
        </div>
        {
          latestPictures.length > 0 ? (
            <div class="home-photo-grid">
              {latestPictures.map((picture, index) => (
                <a class="home-photo-tile" href={picture.href}>
                  <OptimizedImage
                    src={picture.image}
                    alt={picture.alt}
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : "auto"}
                    sizes="(min-width: 1120px) 260px, (min-width: 900px) 25vw, (min-width: 640px) 50vw, 100vw"
                    widths={[240, 360, 520, 720]}
                  />
                  <span>
                    <strong>{picture.title}</strong>
                    <span>{picture.location}</span>
                  </span>
                </a>
              ))}
            </div>
          ) : (
            <p class="empty-state">{pageCopy.photography.emptyState}</p>
          )
        }
      </div>
    </section>

    <section class="home-section reveal">
      <div class="home-panel">
        <div class="home-section__head">
          <h2>{homeCopy.writingTitle}</h2>
        </div>
        <div class="home-blog-list">
          {
            latestWriting.map((post) => (
              <a class="home-blog-card" href={`/blog/${post.slug}`}>
                <span class="meta">{formatDate(post.data.publishDate)}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="home-contact reveal">
      <p class="eyebrow">{homeCopy.contactTitle}</p>
      <a class="button" href="/contact">{homeCopy.contactCtaLabel}</a>
    </section>
  </div>
</Layout>

<style>
  .home-frame {
    display: grid;
    gap: clamp(1.35rem, 3vw, 2.25rem);
  }

  .home-hero {
    display: grid;
    padding-top: 0.35rem;
    padding-bottom: clamp(0.35rem, 1vw, 0.75rem);
    border-bottom: 1px solid var(--line);
  }

  .home-hero h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(2.45rem, 8vw, 5.8rem);
    line-height: 0.98;
  }

  .home-hero__copy {
    display: grid;
    gap: 0.9rem;
    max-width: 72rem;
  }

  .home-deck {
    max-width: 62ch;
    color: var(--muted);
    font-size: clamp(1rem, 1.2vw, 1.12rem);
  }

  .home-panel {
    display: grid;
    gap: clamp(0.95rem, 2vw, 1.25rem);
  }

  .home-section {
    padding-top: clamp(1rem, 2.4vw, 1.45rem);
    border-top: 1px solid var(--line);
  }

  .home-section__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    min-width: 0;
    padding-bottom: 0.15rem;
  }

  .home-section__head h2 {
    font-size: clamp(1.35rem, 2.6vw, 2rem);
  }

  .home-photo-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .home-photo-tile {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    min-height: 0;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--photo-media-bg);
    text-decoration: none;
  }

  .home-photo-tile :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .home-photo-tile:hover :global(img),
  .home-photo-tile:focus-visible :global(img) {
    transform: scale(1.025);
  }

  .home-photo-tile > span {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: grid;
    gap: 0.1rem;
    padding: 0.65rem;
    color: #ffffff;
    background: linear-gradient(
      to top,
      rgba(17, 17, 17, 0.72),
      rgba(17, 17, 17, 0)
    );
  }

  .home-photo-tile strong {
    font-family: var(--font-main);
    font-size: 0.95rem;
    line-height: 1.1;
  }

  .home-photo-tile span span {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.82rem;
  }

  .home-blog-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .home-blog-card {
    display: grid;
    gap: 0.4rem;
    padding: 1rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    transition:
      transform 180ms ease,
      color 180ms ease,
      border-color 180ms ease;
  }

  .home-blog-card:hover,
  .home-blog-card:focus-visible {
    color: var(--accent);
    border-color: var(--line-strong);
    transform: translateX(0.25rem);
  }

  .home-blog-card h3 {
    max-width: 100%;
    font-size: 1.2rem;
  }

  .home-blog-card p {
    max-width: 72ch;
    color: var(--muted);
  }

  .home-contact {
    display: grid;
    gap: 0.65rem;
    justify-items: center;
    padding-top: 0.25rem;
    text-align: center;
  }

  .home-contact .eyebrow {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .home-photo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .home-frame {
      gap: 1.2rem;
    }

    .home-photo-tile > span {
      padding: 0.8rem;
    }

    .home-blog-card h3 {
      font-size: 1.08rem;
    }

    .home-photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

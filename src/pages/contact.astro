---
import { pageCopy, siteConfig } from "@/data/site";
import Layout from "@/layouts/Layout.astro";

const web3FormsAccessKey =
  import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ||
  "8bb517fb-676d-4f01-9abf-e78ede972044";
const contactCopy = pageCopy.contact;
---

<Layout title={contactCopy.seoTitle} description={contactCopy.seoDescription}>
  <div class="frame">
    <section class="contact-page reveal">
      <header class="page-kicker-header">
        <p class="eyebrow">{contactCopy.eyebrow}</p>
      </header>

      <form
        class="contact-form panel"
        action="https://api.web3forms.com/submit"
        data-contact-form
        data-sending-message={contactCopy.sendingMessage}
        data-success-message={contactCopy.successMessage}
        data-error-message={contactCopy.errorMessage}
        name="contact"
        method="post"
      >
        <input type="hidden" name="access_key" value={web3FormsAccessKey} />
        <input
          type="hidden"
          name="subject"
          value={`New contact form submission from ${siteConfig.name}`}
        />

        <label class="form-hidden">
          {contactCopy.honeypotLabel}
          <input
            name="botcheck"
            type="checkbox"
            autocomplete="off"
            tabindex="-1"
          />
        </label>

        <label>
          {contactCopy.nameLabel}
          <input name="name" autocomplete="name" required />
        </label>

        <label>
          {contactCopy.emailLabel}
          <input name="email" type="email" autocomplete="email" required />
        </label>

        <label>
          {contactCopy.messageLabel}
          <textarea name="message" rows="4" required></textarea>
        </label>

        <div class="contact-form__actions">
          <button class="button" type="submit">{contactCopy.submitLabel}</button
          >
          <p class="form-status meta" data-form-status aria-live="polite"></p>
        </div>
      </form>
    </section>
  </div>
</Layout>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = document.querySelector<HTMLElement>("[data-form-status]");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const submitButton = form.querySelector("button[type='submit']");
    const sendingMessage = form.dataset.sendingMessage || "Sending.";
    const successMessage =
      form.dataset.successMessage || "Thanks, your note was sent.";
    const errorMessage =
      form.dataset.errorMessage || "Could not send that message.";

    if (
      !(form instanceof HTMLFormElement) ||
      !(submitButton instanceof HTMLButtonElement)
    ) {
      return;
    }

    submitButton.disabled = true;
    if (status instanceof HTMLElement) {
      status.textContent = sendingMessage;
    }

    try {
      const response = await fetch(form.action, {
        body: new FormData(form),
        headers: { Accept: "application/json" },
        method: "POST",
      });
      const result = await response
        .json()
        .catch(() => ({ message: errorMessage }));

      if (!response.ok || !result.success) {
        throw new Error(result.message || errorMessage);
      }

      form.reset();
      if (status instanceof HTMLElement) {
        status.textContent = successMessage;
      }
    } catch (error) {
      if (status instanceof HTMLElement) {
        status.textContent =
          error instanceof Error ? error.message : errorMessage;
      }
    } finally {
      submitButton.disabled = false;
    }
  });
</script>

<style>
  .contact-page {
    display: grid;
    gap: var(--content-gap);
    width: min(560px, 100%);
    margin: 0 auto;
  }

  .contact-form {
    display: grid;
    gap: 0.8rem;
    padding: var(--panel-padding);
  }

  .contact-form label {
    display: grid;
    gap: 0.35rem;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    color: var(--ink);
    font: inherit;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: var(--control-padding);
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form__actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.35rem;
  }

  .form-hidden {
    position: absolute;
    left: -100vw;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-status {
    text-align: right;
  }

  .form-status:empty {
    display: none;
  }

  @media (max-width: 640px) {
    .contact-form__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .contact-form .button {
      width: 100%;
    }

    .form-status {
      text-align: left;
    }
  }
</style>

---
import { siteConfig } from "@/data/site";
import Layout from "@/layouts/Layout.astro";
import { safeHref } from "@/utils/url";

const projects = siteConfig.projects.map((project) => ({
  ...project,
  href: safeHref(project.href),
}));
---

<Layout
  title="Work"
  description="Projects and selected photography CV for R. Martinez."
  pageType="profile"
>
  <div class="frame">
    <section class="work-page reveal">
      <header class="work-hero">
        <p class="eyebrow">Work</p>
        <h1>Projects and selected CV.</h1>
      </header>

      <section class="work-section panel">
        <div class="work-section__head">
          <h2>Projects</h2>
          <p class="meta">Current and recent things.</p>
        </div>

        {
          projects.length > 0 ? (
            <div class="work-list">
              {projects.map((project) => (
                <a class="work-item" href={project.href}>
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.description}</p>
                  </div>
                  {project.status && <span class="meta">{project.status}</span>}
                </a>
              ))}
            </div>
          ) : (
            <p class="meta">
              Add project links in Pages CMS when you want to share them.
            </p>
          )
        }
      </section>

      <section class="work-section panel">
        <div class="work-section__head">
          <h2>Selected CV</h2>
          <p class="meta">Photography, art, and public showings.</p>
        </div>

        {
          siteConfig.artCv.length > 0 ? (
            <div class="cv-list">
              {siteConfig.artCv.map((item) => (
                <article class="cv-item">
                  <p class="cv-item__year">{item.year}</p>
                  <div>
                    <h3>{item.title}</h3>
                    <p>
                      {item.venue}, {item.location}
                    </p>
                    {item.notes && <p>{item.notes}</p>}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="meta">
              Add exhibitions, screenings, markets, or other showings in Pages
              CMS.
            </p>
          )
        }
      </section>
    </section>
  </div>
</Layout>

<style>
  .work-page {
    display: grid;
    gap: 1.25rem;
  }

  .work-hero {
    display: grid;
    gap: 0.6rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }

  .work-hero h1 {
    font-size: clamp(1.9rem, 4vw, 3.25rem);
  }

  .work-section {
    display: grid;
    gap: 1rem;
  }

  .work-section__head {
    display: grid;
    gap: 0.25rem;
  }

  .work-section__head h2 {
    font-size: 1rem;
  }

  .work-list,
  .cv-list {
    display: grid;
    gap: 0;
  }

  .work-item,
  .cv-item {
    display: grid;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line);
  }

  .work-item {
    grid-template-columns: minmax(0, 1fr) auto;
    text-decoration: none;
  }

  .cv-item {
    grid-template-columns: minmax(5rem, 0.2fr) minmax(0, 1fr);
  }

  .work-item:first-child,
  .cv-item:first-child {
    padding-top: 0;
  }

  .work-item:last-child,
  .cv-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .work-item h3,
  .cv-item h3 {
    font-size: 1rem;
  }

  .work-item p,
  .cv-item p {
    color: var(--muted);
  }

  .cv-item__year {
    color: var(--ink);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .work-item,
    .cv-item {
      grid-template-columns: 1fr;
    }
  }
</style>

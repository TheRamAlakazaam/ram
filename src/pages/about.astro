---
import { pageCopy, siteConfig } from "@/data/site";
import Layout from "@/layouts/Layout.astro";
import { safeHref } from "@/utils/url";

function getStartYear(status?: string) {
  return Number(status?.match(/\b\d{4}\b/)?.[0] || 0);
}

const projects = siteConfig.projects
  .map((project) => ({
    ...project,
    href: safeHref(project.href),
  }))
  .sort((a, b) => getStartYear(b.status) - getStartYear(a.status));
const aboutCopy = pageCopy.about;
const hasSummary = siteConfig.summary.trim().length > 0;
---

<Layout
  title={aboutCopy.seoTitle}
  description={aboutCopy.seoDescription}
  pageType="profile"
>
  <div class="frame">
    <section class="about-page reveal">
      <header class="about-hero page-kicker-header">
        <p class="eyebrow">{aboutCopy.heroEyebrow}</p>
      </header>

      <section class="about-section panel">
        <div class="about-section__head">
          <h2>{aboutCopy.summaryTitle}</h2>
        </div>

        {
          hasSummary ? (
            <div class="about-section__body about-summary">
              <p class="lede">{siteConfig.summary}</p>
            </div>
          ) : (
            <p class="meta about-section__body">
              {aboutCopy.summaryEmptyState}
            </p>
          )
        }
      </section>

      <section class="about-section panel">
        <div class="about-section__head">
          <h2>{aboutCopy.projectsTitle}</h2>
        </div>

        {
          projects.length > 0 ? (
            <div class="about-section__body about-list">
              {projects.map((project) => (
                <a class="about-item" href={project.href}>
                  <div>
                    <h3>{project.title}</h3>
                    <p>{project.description}</p>
                  </div>
                  {project.status && <span class="meta">{project.status}</span>}
                </a>
              ))}
            </div>
          ) : (
            <p class="meta about-section__body">
              {aboutCopy.projectsEmptyState}
            </p>
          )
        }
      </section>

      <section class="about-section panel">
        <div class="about-section__head">
          <h2>{aboutCopy.cvTitle}</h2>
        </div>

        {
          siteConfig.artCv.length > 0 ? (
            <div class="about-section__body cv-list">
              {siteConfig.artCv.map((item) => (
                <article class="cv-item">
                  <p class="cv-item__year">{item.year}</p>
                  <div>
                    <h3>
                      {item.titleStyle === "italic" ? (
                        <em>{item.title}</em>
                      ) : (
                        item.title
                      )}
                    </h3>
                    <p>
                      {item.venue}, {item.location}
                    </p>
                    {item.notes && <p>{item.notes}</p>}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <p class="meta about-section__body">{aboutCopy.cvEmptyState}</p>
          )
        }
      </section>
    </section>
  </div>
</Layout>

<style>
  .about-page {
    display: grid;
    gap: var(--section-gap);
  }

  .about-section {
    display: grid;
    gap: var(--content-gap);
  }

  .about-section__head {
    display: grid;
    gap: 0.35rem;
    padding-bottom: var(--divider-padding);
    border-bottom: 1px solid var(--line);
  }

  .about-section__head h2 {
    font-size: 1.02rem;
    letter-spacing: 0.03em;
  }

  .about-section__body {
    padding-top: 0;
  }

  .about-summary .lede,
  .about-item p,
  .cv-item p {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  .about-section .meta,
  .cv-item__year {
    font-family: var(--font-main);
    font-size: 0.98rem;
    line-height: 1.7;
    letter-spacing: 0.01em;
  }

  .about-summary .lede {
    max-width: none;
  }

  .about-list,
  .cv-list {
    display: grid;
    gap: 0;
  }

  .about-item,
  .cv-item {
    display: grid;
    gap: var(--content-gap);
    padding: var(--item-padding);
    border-bottom: 1px solid var(--line);
  }

  .about-item {
    grid-template-columns: minmax(0, 1fr) auto;
    text-decoration: none;
  }

  .cv-item {
    grid-template-columns: minmax(5rem, 0.2fr) minmax(0, 1fr);
  }

  .about-item:first-child,
  .cv-item:first-child {
    padding-top: 0;
  }

  .about-item:last-child,
  .cv-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .about-item h3,
  .cv-item h3 {
    font-size: 1rem;
    letter-spacing: 0.03em;
  }

  .about-item p,
  .cv-item p {
    color: var(--muted);
  }

  .cv-item__year {
    color: var(--ink);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .about-item,
    .cv-item {
      grid-template-columns: 1fr;
    }
  }
</style>

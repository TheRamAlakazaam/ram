---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";
import { getCollection, render } from "astro:content";

import OptimizedImage from "@/components/OptimizedImage.astro";
import PhotoSpotlight from "@/components/PhotoSpotlight.astro";
import { pageCopy } from "@/data/site";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/utils/content";
import {
  formatAlbumImageCount,
  getAlbumCoverAlt,
  getAlbumCoverImage,
  getAlbumGallery,
} from "@/utils/photography";

export async function getStaticPaths() {
  const photos = await getCollection("photos");

  return photos.map((photo) => ({
    params: { slug: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const { Content } = await render(photo);
const photographyCopy = pageCopy.photography;
const coverImage = getAlbumCoverImage(photo.data);
const coverAlt = getAlbumCoverAlt(photo.data);
const gallery = getAlbumGallery(photo.data);
const hasBody = (photo.body || "").trim().length > 0;
const showHero = gallery.length <= 1;
const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/**/*.{avif,gif,jpeg,jpg,png,webp}",
);

async function getSpotlightSrc(src?: string) {
  if (!src) {
    return "";
  }

  const normalizedSrc = src.replace(/^\/?src\/assets\//, "/assets/");
  const imageKey = normalizedSrc.startsWith("/assets/")
    ? normalizedSrc.replace(/^\/assets\//, "/src/assets/")
    : normalizedSrc;
  const imageImport = images[imageKey];

  if (!imageImport) {
    return normalizedSrc;
  }

  const importedImage = (await imageImport()).default;
  const spotlightImage = await getImage({
    src: importedImage,
    width: Math.min(1200, importedImage.width),
    format: "webp",
  });

  return spotlightImage.src;
}

const coverSpotlightSrc = await getSpotlightSrc(coverImage);
const gallerySpotlight = await Promise.all(
  gallery.map(async (image, index) => ({
    image,
    label: `${photo.data.title} ${index + 1}`,
    spotlightSrc: await getSpotlightSrc(image),
  })),
);
---

<Layout
  title={photo.data.title}
  description={photo.data.description}
  image={coverImage}
  keywords={photo.data.tags}
  pageType="article"
  structuredType="ImageGallery"
  publishDate={photo.data.publishDate}
>
  <article
    class:list={["article-shell", { "article-shell--gallery": !showHero }]}
  >
    <header class="article-header article-header--center panel reveal">
      <p class="eyebrow">{photographyCopy.articleEyebrow}</p>
      <h1>{photo.data.title}</h1>
      <p class="lede">{photo.data.description}</p>
      <div class="article-meta">
        <span class="meta">{photo.data.location}</span>
        <span class="meta">{formatDate(photo.data.publishDate)}</span>
        <span class="meta">{formatAlbumImageCount(gallery.length)}</span>
      </div>
    </header>

    {
      showHero && (
        <div class="photo-hero reveal">
          {coverImage ? (
            <button
              class="spotlight-trigger photo-hero__button"
              type="button"
              data-spotlight-trigger
              data-spotlight-src={coverSpotlightSrc}
              data-spotlight-label={coverAlt}
              aria-label={`Open ${coverAlt} in image spotlight`}
            >
              <OptimizedImage
                src={coverImage}
                alt={coverAlt}
                loading="eager"
                fetchpriority="high"
                sizes="(min-width: 900px) 860px, 100vw"
                widths={[720, 960, 1200]}
              />
            </button>
          ) : (
            <div class="photo-hero__placeholder">
              <span>{coverAlt}</span>
            </div>
          )}
        </div>
      )
    }

    {
      gallery.length > 1 && (
        <section class="album-gallery panel reveal">
          <div class="album-gallery__grid">
            {gallerySpotlight.map(({ image, label, spotlightSrc }) => (
              <figure class="album-gallery__item">
                <button
                  class="spotlight-trigger"
                  type="button"
                  data-spotlight-trigger
                  data-spotlight-src={spotlightSrc}
                  data-spotlight-label={label}
                  aria-label={`Open ${label} in spotlight`}
                >
                  <OptimizedImage
                    src={image}
                    alt={label}
                    sizes="(min-width: 1200px) 280px, (min-width: 900px) 33vw, (min-width: 640px) 50vw, 100vw"
                    widths={[360, 520, 720, 960]}
                  />
                </button>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    {
      hasBody && (
        <div class="article-content panel reveal prose">
          <Content />
        </div>
      )
    }
  </article>

  <PhotoSpotlight />
</Layout>

<style>
  .article-shell--gallery {
    width: min(1220px, calc(100% - var(--page-gutter) - var(--page-gutter)));
  }

  .photo-hero {
    display: grid;
    place-items: center;
    min-height: 0;
    padding: 0;
  }

  .spotlight-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: zoom-in;
    font: inherit;
  }

  .photo-hero :global(picture),
  .photo-hero :global(img),
  .photo-hero__button {
    display: block;
    width: 100%;
  }

  .photo-hero :global(img) {
    height: auto;
    max-height: min(82svh, 1100px);
    object-fit: contain;
  }

  .album-gallery {
    padding: var(--panel-padding);
  }

  .album-gallery__grid {
    column-count: 3;
    column-gap: 0.85rem;
  }

  .album-gallery__item {
    break-inside: avoid;
    display: block;
    margin: 0;
    margin-bottom: 0.85rem;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--surface-strong);
  }

  .album-gallery__item :global(picture),
  .album-gallery__item :global(img),
  .album-gallery__item .spotlight-trigger {
    display: block;
    width: 100%;
  }

  .album-gallery__item :global(img) {
    height: auto;
  }

  @media (max-width: 900px) {
    .article-shell--gallery {
      width: min(1000px, calc(100% - var(--page-gutter) - var(--page-gutter)));
    }

    .album-gallery__grid {
      column-count: 2;
    }
  }

  @media (max-width: 640px) {
    .article-shell--gallery {
      width: min(1220px, calc(100% - var(--page-gutter) - var(--page-gutter)));
    }

    .album-gallery__grid {
      column-count: 1;
    }
  }
</style>
